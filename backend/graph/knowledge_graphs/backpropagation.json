  ],
  "nodes": [
    { "id": "Model_Output",              "label": "Model Output",               "type": "concept",        "chapter_id": "CH_1", "difficulty": 1, "importance": 4, "description": "The value produced by the network given an input — the prediction before comparing to the target." },
    { "id": "Target_Label",              "label": "Target Label",               "type": "concept",        "chapter_id": "CH_1", "difficulty": 1, "importance": 4, "description": "The ground-truth value the network is trying to predict." },
    { "id": "Prediction_Error",          "label": "Prediction Error",           "type": "concept",        "chapter_id": "CH_1", "difficulty": 1, "importance": 4, "description": "The difference between the model output and the target label, measuring how wrong the prediction is." },
    { "id": "Loss_Function",             "label": "Loss Function",              "type": "function",       "chapter_id": "CH_1", "difficulty": 2, "importance": 5, "description": "A scalar function that quantifies prediction error in a differentiable way so the network can be trained.", "mastery_required": true },
    { "id": "Optimization_Objective",    "label": "Optimization Objective",     "type": "concept",        "chapter_id": "CH_1", "difficulty": 2, "importance": 4, "description": "The formal goal of training: minimize the loss function over the training data." },
    { "id": "Gradient",                  "label": "Gradient",                   "type": "concept",        "chapter_id": "CH_1", "difficulty": 3, "importance": 5, "description": "A vector of partial derivatives indicating the direction and magnitude of steepest loss increase.", "mastery_required": true },

    { "id": "Computational_Graph",       "label": "Computational Graph",        "type": "representation", "chapter_id": "CH_2", "difficulty": 2, "importance": 5, "description": "A directed acyclic graph where nodes are operations and edges carry data — the structure backprop traverses in reverse.", "mastery_required": true },
    { "id": "Node",                      "label": "Node",                       "type": "concept",        "chapter_id": "CH_2", "difficulty": 1, "importance": 3, "description": "An operation or variable in the computational graph (e.g. multiply, add, relu)." },
    { "id": "Edge",                      "label": "Edge",                       "type": "concept",        "chapter_id": "CH_2", "difficulty": 1, "importance": 3, "description": "A directed connection in the computational graph carrying the output of one operation as input to the next." },
    { "id": "Local_Derivative",          "label": "Local Derivative",           "type": "concept",        "chapter_id": "CH_2", "difficulty": 2, "importance": 4, "description": "The derivative of a node's output with respect to its own input — computed independently at each node." },
    { "id": "Partial_Derivative",        "label": "Partial Derivative",         "type": "concept",        "chapter_id": "CH_2", "difficulty": 2, "importance": 4, "description": "Derivative of the loss with respect to one specific variable, holding all others constant." },
    { "id": "Chain_Rule",                "label": "Chain Rule",                 "type": "rule",           "chapter_id": "CH_2", "difficulty": 3, "importance": 5, "description": "d(f∘g)/dx = f'(g(x))·g'(x) — the mathematical foundation that lets gradients propagate through composed functions.", "mastery_required": true },
    { "id": "Gradient_Composition",      "label": "Gradient Composition",       "type": "process",        "chapter_id": "CH_2", "difficulty": 3, "importance": 4, "description": "Multiplying local derivatives along a path in the computational graph to obtain the total gradient." },

    { "id": "Forward_Pass",              "label": "Forward Pass",               "type": "process",        "chapter_id": "CH_3", "difficulty": 2, "importance": 5, "description": "Left-to-right computation producing the model output and caching intermediate values for backprop.", "mastery_required": true },
    { "id": "Intermediate_Activation",   "label": "Intermediate Activation",    "type": "concept",        "chapter_id": "CH_3", "difficulty": 2, "importance": 4, "description": "The output of a hidden layer node — computed during the forward pass and needed by the backward pass." },
    { "id": "Cached_Values",             "label": "Cached Values",              "type": "concept",        "chapter_id": "CH_3", "difficulty": 2, "importance": 4, "description": "Intermediate activations stored during the forward pass so that backprop can compute local derivatives without recomputing." },
    { "id": "Backward_Pass",             "label": "Backward Pass",              "type": "process",        "chapter_id": "CH_3", "difficulty": 3, "importance": 5, "description": "Right-to-left traversal of the computational graph applying the chain rule to compute gradients for all parameters.", "mastery_required": true },
    { "id": "Upstream_Gradient",         "label": "Upstream Gradient",          "type": "concept",        "chapter_id": "CH_3", "difficulty": 3, "importance": 4, "description": "The gradient flowing into a node from the loss side — multiplied by the local derivative to get the downstream gradient." },
    { "id": "Gradient_Flow",             "label": "Gradient Flow",              "type": "process",        "chapter_id": "CH_3", "difficulty": 3, "importance": 4, "description": "The propagation of upstream gradients backward through the network layer by layer." },
    { "id": "Parameter_Gradient",        "label": "Parameter Gradient",         "type": "concept",        "chapter_id": "CH_3", "difficulty": 3, "importance": 5, "description": "The partial derivative of the loss with respect to a specific weight or bias — used to update that parameter.", "mastery_required": true },

    { "id": "Weight",                    "label": "Weight",                     "type": "parameter",      "chapter_id": "CH_4", "difficulty": 1, "importance": 5, "description": "A learnable scalar that scales an input signal in a linear transformation.", "mastery_required": true },
    { "id": "Bias",                      "label": "Bias",                       "type": "parameter",      "chapter_id": "CH_4", "difficulty": 1, "importance": 4, "description": "A learnable offset added after the weighted sum, allowing the activation threshold to shift." },
    { "id": "Linear_Transformation",     "label": "Linear Transformation",      "type": "function",       "chapter_id": "CH_4", "difficulty": 2, "importance": 3, "description": "A mapping of the form z = Wx — scaling and rotating inputs with no translation." },
    { "id": "Affine_Transformation",     "label": "Affine Transformation",      "type": "function",       "chapter_id": "CH_4", "difficulty": 2, "importance": 4, "description": "A mapping of the form z = Wx + b — linear transformation plus a bias shift." },
    { "id": "Parameter_Update",          "label": "Parameter Update",           "type": "process",        "chapter_id": "CH_4", "difficulty": 2, "importance": 5, "description": "Adjusting weights and biases by subtracting learning_rate × gradient to reduce the loss.", "mastery_required": true },

    { "id": "Activation_Function",       "label": "Activation Function",        "type": "activation",     "chapter_id": "CH_5", "difficulty": 2, "importance": 5, "description": "A nonlinear function applied after affine transformation — without it, deep networks collapse to a single linear layer.", "mastery_required": true },
    { "id": "Sigmoid_Function",          "label": "Sigmoid",                    "type": "activation",     "chapter_id": "CH_5", "difficulty": 2, "importance": 4, "description": "σ(x) = 1/(1+e⁻ˣ) — squashes output to (0,1); historically popular but prone to vanishing gradients." },
    { "id": "ReLU_Function",             "label": "ReLU",                       "type": "activation",     "chapter_id": "CH_5", "difficulty": 2, "importance": 5, "description": "max(0,x) — computationally cheap, avoids vanishing gradient for positive inputs; the default choice today.", "mastery_required": true },
    { "id": "Tanh_Function",             "label": "Tanh",                       "type": "activation",     "chapter_id": "CH_5", "difficulty": 2, "importance": 3, "description": "Squashes output to (-1,1); zero-centered unlike sigmoid, but still saturates and causes vanishing gradients." },
    { "id": "Softmax_Function",          "label": "Softmax",                    "type": "activation",     "chapter_id": "CH_5", "difficulty": 3, "importance": 4, "description": "Converts a vector of logits to a probability distribution summing to 1 — used in the output layer for classification." },
    { "id": "Activation_Derivative",     "label": "Activation Derivative",      "type": "concept",        "chapter_id": "CH_5", "difficulty": 3, "importance": 5, "description": "The local derivative of an activation function — multiplied by the upstream gradient during backprop.", "mastery_required": true },

    { "id": "Mean_Squared_Error",        "label": "Mean Squared Error",         "type": "loss",           "chapter_id": "CH_6", "difficulty": 2, "importance": 4, "description": "L = (1/n)Σ(ŷᵢ−yᵢ)² — standard loss for regression; penalizes large errors quadratically." },
    { "id": "Cross_Entropy_Loss",        "label": "Cross-Entropy Loss",         "type": "loss",           "chapter_id": "CH_6", "difficulty": 3, "importance": 5, "description": "L = −Σ yᵢ log(ŷᵢ) — standard loss for classification; derived from maximum likelihood.", "mastery_required": true },
    { "id": "Log_Likelihood",            "label": "Log Likelihood",             "type": "concept",        "chapter_id": "CH_6", "difficulty": 3, "importance": 3, "description": "The log probability of observing the training labels under the model — maximizing it is equivalent to minimizing cross-entropy." },
    { "id": "Loss_Gradient",             "label": "Loss Gradient",              "type": "concept",        "chapter_id": "CH_6", "difficulty": 3, "importance": 5, "description": "∂L/∂ŷ — the starting signal of backpropagation, computed analytically from the loss function.", "mastery_required": true },
    { "id": "Gradient_Stability",        "label": "Gradient Stability",         "type": "concept",        "chapter_id": "CH_6", "difficulty": 4, "importance": 3, "description": "The property of a loss/activation combination that keeps gradients in a reasonable magnitude range during training." },

    { "id": "Gradient_Descent",          "label": "Gradient Descent",           "type": "algorithm",      "chapter_id": "CH_7", "difficulty": 2, "importance": 5, "description": "θ ← θ − η·∇L — iteratively updates parameters in the direction that reduces the loss.", "mastery_required": true },
    { "id": "Stochastic_Gradient_Descent","label": "SGD",                       "type": "algorithm",      "chapter_id": "CH_7", "difficulty": 2, "importance": 5, "description": "Gradient descent applied to a single or small batch of examples instead of the full dataset — noisier but much faster per step.", "mastery_required": true },
    { "id": "Mini_Batch_Training",       "label": "Mini-Batch Training",        "type": "process",        "chapter_id": "CH_7", "difficulty": 2, "importance": 4, "description": "Using a fixed-size subset of training data per update step — balances the efficiency of batching with the variance-reduction of averaging." },
    { "id": "Learning_Rate",             "label": "Learning Rate",              "type": "parameter",      "chapter_id": "CH_7", "difficulty": 2, "importance": 5, "description": "The scalar η controlling step size in gradient descent — too large causes divergence, too small causes slow convergence.", "mastery_required": true },
    { "id": "Convergence",               "label": "Convergence",                "type": "concept",        "chapter_id": "CH_7", "difficulty": 3, "importance": 4, "description": "The state where further training produces negligible improvement — gradients approach zero near a local or global minimum." },
    { "id": "Update_Dynamics",           "label": "Update Dynamics",            "type": "process",        "chapter_id": "CH_7", "difficulty": 3, "importance": 3, "description": "How parameter values evolve step by step — shaped by gradient magnitude, learning rate, momentum, and noise." },

    { "id": "Vanishing_Gradient",        "label": "Vanishing Gradient",         "type": "pathology",      "chapter_id": "CH_8", "difficulty": 3, "importance": 5, "description": "Gradients become exponentially small as they backpropagate through many layers, stalling learning in early layers.", "mastery_required": true },
    { "id": "Exploding_Gradient",        "label": "Exploding Gradient",         "type": "pathology",      "chapter_id": "CH_8", "difficulty": 3, "importance": 4, "description": "Gradients grow exponentially during backprop, causing unstable or diverging updates." },
    { "id": "Gradient_Scaling",          "label": "Gradient Scaling",           "type": "process",        "chapter_id": "CH_8", "difficulty": 3, "importance": 3, "description": "Techniques such as gradient clipping or mixed-precision training that keep gradient magnitudes in a healthy range." },
    { "id": "Initialization_Strategy",   "label": "Initialization Strategy",    "type": "process",        "chapter_id": "CH_8", "difficulty": 3, "importance": 4, "description": "How weights are set before training (e.g. Xavier, He) to ensure gradients neither vanish nor explode at the start." },
    { "id": "Numerical_Stability",       "label": "Numerical Stability",        "type": "concept",        "chapter_id": "CH_8", "difficulty": 4, "importance": 3, "description": "Avoiding floating-point overflow/underflow during forward and backward passes through careful arithmetic choices." },

    { "id": "Vectorized_Computation",    "label": "Vectorized Computation",     "type": "system",         "chapter_id": "CH_9", "difficulty": 2, "importance": 4, "description": "Expressing operations as matrix/vector operations so GPUs can parallelize them efficiently." },
    { "id": "Matrix_Backpropagation",    "label": "Matrix Backpropagation",     "type": "process",        "chapter_id": "CH_9", "difficulty": 4, "importance": 4, "description": "Generalization of scalar backprop to Jacobian-vector products — required when weights and activations are matrices/tensors." },
    { "id": "Automatic_Differentiation","label": "Automatic Differentiation",   "type": "system",         "chapter_id": "CH_9", "difficulty": 3, "importance": 5, "description": "Software that automatically computes exact derivatives by recording operations at runtime — the engine behind PyTorch/JAX.", "mastery_required": true },
    { "id": "Reverse_Mode_AD",           "label": "Reverse-Mode AD",            "type": "algorithm",      "chapter_id": "CH_9", "difficulty": 4, "importance": 5, "description": "One backward pass computes gradients for all inputs simultaneously — efficient when outputs are fewer than inputs (like a scalar loss).", "mastery_required": true },
    { "id": "Computation_Graph_Traversal","label": "Graph Traversal",           "type": "algorithm",      "chapter_id": "CH_9", "difficulty": 3, "importance": 4, "description": "The topological-order traversal of the computational graph during backprop — each node is visited exactly once." },
    { "id": "Memory_Computation_Tradeoff","label": "Memory-Computation Tradeoff","type": "concept",       "chapter_id": "CH_9", "difficulty": 4, "importance": 3, "description": "Caching all activations is fast but memory-intensive; gradient checkpointing recomputes some forward values to save memory." }
  ],
